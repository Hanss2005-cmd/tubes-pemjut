rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /videos/{allPaths=**} {
      // Izinkan baca publik agar pengunjung situs bisa menonton video/audio
      allow read: if true;
      // Izinkan tulis (unggah/hapus) hanya jika user sudah login (autentikasi admin)
      allow write: if request.auth != null;
    }
  }
}
